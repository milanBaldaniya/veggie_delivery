NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

MONGO_URI=mongodb://127.0.0.1:27017/veggie_delivery

JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# Ordering window — customers can only order before this hour (24h clock) in the
# given IANA timezone. After the cutoff they see "Order window is closed".
ORDER_CUTOFF_HOUR=12
ORDER_TIMEZONE=Asia/Kolkata

# Weekly bill finalization schedule (cron, runs in ORDER_TIMEZONE).
# Default: Monday 00:05 — closes out the week that just ended.
WEEKLY_BILLING_CRON=5 0 * * 1

# Google Sign-In — comma-separated list of every OAuth client ID whose ID
# tokens the backend should accept. Include the Web client ID (also used as the
# mobile app's webClientId) and the iOS client ID. Get them from the Google
# Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-ios-client-id.apps.googleusercontent.com

CORS_ORIGIN=*

# Cloudinary (product image uploads) — get these from your Cloudinary dashboard.
# Uploads are disabled until all three are set.
CLOUDINARY_CLOUD_NAME=ovor39bp
CLOUDINARY_API_KEY=355932848114237
CLOUDINARY_API_SECRET=TUS3V4zTIPVPR2VLM2hQRgh62pY
# Folder images are stored under in Cloudinary.
CLOUDINARY_FOLDER=veggie-delivery/products

# Default Super Admin created by `node src/seeders/admin.seed.js` (optional).
SEED_ADMIN_EMAIL=admin@veggie.local
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Super Admin
